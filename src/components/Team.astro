---
import { Image } from 'astro:assets';
import abigailImg from '/public/assets/img/team/Abigail.jpg';
import josephImg from '/public/assets/img/team/Joseph.jpg';
import phylImg from '/public/assets/img/team/Phyl.jpg';

const teamMembers = [
  {
    image: abigailImg,
    name: 'Abigail Woolley',
    role: 'Co-founder & Machine Learning Engineer',
  },
  {
    image: josephImg,
    name: 'Joseph Afriyie Attakorah',
    role: 'Software Engineer',
  },
  {
    image: phylImg,
    name: 'Philomena Ahinei Amartey',
    role: 'Project Manager',
  },
];
---

<!-- Team Section -->
<section class="showcase" id="team" aria-labelledby="team-title">
  <h2 class="section-title" id="team-title">Our Lead <span>Experts</span></h2>
  <div class="hexagon-container">
    {teamMembers.map((member) => (
      <div class="hexagon">
        <div class="hexagon-inner glass">
          <Image
            src={member.image}
            alt={`${member.name}, ${member.role}`}
            class="team-photo"
            width={400}
            height={400}
            loading="lazy"
          />
          <h4>{member.name}</h4>
          <p>{member.role}</p>
        </div>
      </div>
    ))}
  </div>
</section>
